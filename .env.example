# ---- Supabase (client-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ---- Server-only secrets ----
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Direct Postgres connections (Edge Functions / cron / scripts) MUST use the
# Supavisor pooler host. Never use the direct db.<ref>.supabase.co:5432 host.
# Transaction mode (recommended for serverless): port 6543
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ---- SMTP (Phase 2/4 email engine) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.account@gmail.com
SMTP_PASS=your16charapppassword

# ---- Anthropic (Phase 5 AI engine) ----
MOONSHOT_API_KEY=sk-moon-...

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TZ=Asia/Kolkata

# ---- Cron / queue worker auth ----
CRON_SECRET=generate-a-long-random-string

# ---- AI engine ----
ANTHROPIC_MODEL=claude-sonnet-4-6
